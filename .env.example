# data-fetcher-pipeline Environment Variables Example

# Kaggle Credentials (Required for Kaggle datasets)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# SEC EDGAR Credentials (Required for financial filings)
SEC_API_KEY=your_sec_api_key

# FRED Credentials (Required for macroeconomic data)
FRED_API_KEY=your_fred_api_key

# Optional: Override the output directory for Docker or custom setups
# OUTPUT_DIR=/output
